# 域名配置
DOMAIN=your-domain.com

# 管理员账号配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here
ADMIN_EMAIL=admin@example.com

# Telegram Bot Token（可选）
# 获取方式：https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# API Keys（可选）
# Anthropic API Key（用于 Claude 模型）
ANTHROPIC_API_KEY=

# OpenAI API Key（用于 GPT 模型）
OPENAI_API_KEY=

# OpenClaw 版本
# 留空或设置为 "latest" 使用最新版本
# 或指定版本号，如 "2026.3.2"
OPENCLAW_VERSION=latest

# Watchtower 更新间隔（秒）
# 86400 = 每天检查一次
# 43200 = 每12小时检查一次
# 3600 = 每小时检查一次
WATCHTOWER_INTERVAL=86400

# 时区
TZ=Asia/Shanghai
